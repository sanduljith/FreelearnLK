{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational course containing videos.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "instructorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "instructorId", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "Video lesson within a course.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "youtubeVideoId", "order", "createdAt"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Link between a student and a course granting access.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "enrolledAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course metadata"
    },
    "/courses/{courseId}/videos/{videoId}": {
      "schema": "Video",
      "description": "Videos in a course"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Student course access"
    }
  }
}
